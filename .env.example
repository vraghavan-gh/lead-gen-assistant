# Lead Gen Assistant - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Databricks ───────────────────────────────────────────
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_personal_access_token
DATABRICKS_WORKSPACE_ID=your_workspace_id
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# ── LLM Provider ─────────────────────────────────────────
# Choose ONE provider: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Your API key for the chosen provider
LLM_API_KEY=your_api_key_here

# Optional: override the default model
# LLM_MODEL=claude-sonnet-4-20250514   # Anthropic default
# LLM_MODEL=gpt-4o                     # OpenAI default
# LLM_MODEL=gemini-1.5-pro             # Gemini default

# ── Provider-specific keys (alternative to LLM_API_KEY) ──
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# ── LangGuard Control Plane ───────────────────────────────
LANGGUARD_ENABLED=true
LANGGUARD_TIER=free
